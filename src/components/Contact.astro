---
/**
 * Componente Contact — seção de contato com formulário.
 *
 * REGRA DA SKILL: "Arquitetura de Ilhas" usada APENAS aqui porque o
 * formulário exige interatividade. O JavaScript enviado é mínimo e
 * usa apenas as APIs nativas do navegador (fetch + FormData).
 */
import type { ContactSection } from '@/types/cms';

interface Props {
  data: ContactSection;
}

const { data } = Astro.props;
---

<section id="contato" class="contact section" aria-labelledby="contact-heading">
  <div class="container">
    <h2 id="contact-heading" class="contact__heading">{data.heading}</h2>
    <p class="contact__subheading">{data.subheading}</p>

    <!--
      Formulário de contato.
      Usa client:idle (Ilha Astro) para hidratar só quando o browser estiver ocioso.
      O script inline é pequeno e não depende de bibliotecas externas.
    -->
    <form
      id="contact-form"
      class="contact__form"
      data-email={data.email}
      novalidate
    >
      <div class="form-group">
        <label for="name" class="form-label">Nome *</label>
        <input
          type="text"
          id="name"
          name="name"
          class="form-input"
          required
          autocomplete="name"
          placeholder="Seu nome completo"
        />
      </div>

      <div class="form-group">
        <label for="email" class="form-label">E-mail *</label>
        <input
          type="email"
          id="email"
          name="email"
          class="form-input"
          required
          autocomplete="email"
          placeholder="seu@email.com"
        />
      </div>

      <div class="form-group">
        <label for="message" class="form-label">Mensagem *</label>
        <textarea
          id="message"
          name="message"
          class="form-input form-input--textarea"
          rows="5"
          required
          placeholder="Como podemos ajudar você?"
        ></textarea>
      </div>

      <button type="submit" class="btn btn--submit">
        {data.submitText}
      </button>

      <p id="form-status" class="form-status" aria-live="polite" hidden></p>
    </form>

    {data.whatsapp && (
      <p class="contact__whatsapp">
        Prefere o WhatsApp?{' '}
        <a
          href={`https://wa.me/${data.whatsapp}`}
          target="_blank"
          rel="noopener noreferrer"
          class="contact__whatsapp-link"
        >
          Clique aqui para conversar →
        </a>
      </p>
    )}
  </div>
</section>

<!--
  Script mínimo de submissão do formulário via Formspree (ou endpoint próprio).
  Não depende de frameworks. < 500 bytes após minificação.
-->
<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status') as HTMLParagraphElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;

    const data = new FormData(form);

    try {
      // Adapte a URL do endpoint conforme seu backend ou Formspree
      const response = await fetch('/api/contact', {
        method: 'POST',
        body: JSON.stringify(Object.fromEntries(data)),
        headers: { 'Content-Type': 'application/json' },
      });

      if (response.ok) {
        status.textContent = '✅ Mensagem enviada! Entraremos em contato em breve.';
        status.className = 'form-status form-status--success';
        form.reset();
      } else {
        throw new Error('Resposta não OK');
      }
    } catch {
      status.textContent = '❌ Ops! Algo deu errado. Tente pelo WhatsApp.';
      status.className = 'form-status form-status--error';
    }

    status.hidden = false;
  });
</script>

<style>
  .contact {
    background: #f8f9fa;
  }

  .contact__heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 0.75rem;
    color: #1a1a2e;
  }

  .contact__subheading {
    text-align: center;
    color: #6c757d;
    margin-bottom: 2.5rem;
  }

  .contact__form {
    max-width: 620px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label {
    font-weight: 600;
    font-size: 0.875rem;
    color: #1a1a2e;
  }

  .form-input {
    padding: 0.75rem 1rem;
    border: 1.5px solid #ced4da;
    border-radius: 8px;
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 0.15s ease;
    background: #fff;
  }

  .form-input:focus {
    outline: none;
    border-color: #302b63;
    box-shadow: 0 0 0 3px rgba(48, 43, 99, 0.1);
  }

  .form-input--textarea {
    resize: vertical;
    min-height: 120px;
  }

  .btn--submit {
    align-self: flex-start;
    background: #302b63;
    color: #fff;
    padding: 0.875rem 2rem;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .btn--submit:hover {
    background: #0f0c29;
    transform: translateY(-2px);
  }

  .form-status {
    font-size: 0.9rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
  }

  .form-status--success { background: #d1fae5; color: #065f46; }
  .form-status--error   { background: #fee2e2; color: #991b1b; }

  .contact__whatsapp {
    text-align: center;
    margin-top: 2rem;
    color: #6c757d;
    font-size: 0.95rem;
  }

  .contact__whatsapp-link {
    color: #302b63;
    font-weight: 600;
    text-decoration: none;
  }

  .contact__whatsapp-link:hover { text-decoration: underline; }
</style>
