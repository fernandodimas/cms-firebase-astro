---
/**
 * UpdateBanner.astro  (v2)
 *
 * Melhorias v2:
 *  - PAT persistente em localStorage (com botão "Esquecer")
 *  - Seletor de bump: patch | minor | major
 *  - client_payload inclui bump_type → deploy.yml decide como incrementar
 */

interface Props {
  currentVersion: string;
  repoOwner: string;
  repoName: string;
}

const { currentVersion, repoOwner, repoName } = Astro.props;
---

<!-- Banner oculto por padrão — JS o exibe apenas se houver update -->
<div
  id="update-banner"
  class="update-banner"
  hidden
  role="alert"
  aria-live="polite"
  data-current-version={currentVersion}
  data-repo-owner={repoOwner}
  data-repo-name={repoName}
>
  <div class="update-banner__content">
    <span class="update-banner__icon" aria-hidden="true">🔄</span>

    <div class="update-banner__text">
      <strong class="update-banner__title">Nova versão de template disponível!</strong>
      <span class="update-banner__subtitle" id="update-versions"></span>
    </div>

    <div class="update-banner__actions">
      <!-- PAT -->
      <label for="github-pat" class="update-banner__pat-label">
        GitHub Token (PAT)
      </label>
      <div class="update-banner__pat-wrap">
        <input
          type="password"
          id="github-pat"
          class="update-banner__pat-input"
          placeholder="ghp_…"
          autocomplete="off"
          spellcheck="false"
        />
        <button
          id="forget-pat-btn"
          class="update-banner__btn update-banner__btn--ghost"
          type="button"
          title="Esquecer token salvo"
          hidden
        >
          🗑
        </button>
      </div>

      <!-- Seletor de bump -->
      <div class="update-banner__bump-wrap" role="group" aria-label="Tipo de incremento de versão">
        <label class="update-banner__bump-label">Tipo de update:</label>
        <label class="update-banner__bump-opt">
          <input type="radio" name="bump-type" value="patch" checked /> patch
        </label>
        <label class="update-banner__bump-opt">
          <input type="radio" name="bump-type" value="minor" /> minor
        </label>
        <label class="update-banner__bump-opt">
          <input type="radio" name="bump-type" value="major" /> major
        </label>
      </div>

      <button
        id="update-btn"
        class="update-banner__btn update-banner__btn--primary"
        type="button"
      >
        Aplicar Atualização
      </button>
    </div>
  </div>

  <!-- Feedback do processo -->
  <p id="update-status" class="update-banner__status" hidden aria-live="assertive"></p>
</div>

<script defer>
(function () {
  'use strict';

  var PAT_KEY = 'cms_github_pat';

  var banner   = document.getElementById('update-banner');
  if (!banner) return;

  var owner    = banner.dataset.repoOwner;
  var repo     = banner.dataset.repoName;
  var localVer = banner.dataset.currentVersion || '0.0.0';

  // ── PAT persistente ──────────────────────────────────────────────────

  var patInput    = document.getElementById('github-pat');
  var forgetBtn   = document.getElementById('forget-pat-btn');

  function loadPat() {
    try {
      var saved = localStorage.getItem(PAT_KEY);
      if (saved && patInput) {
        patInput.value = saved;
        forgetBtn && (forgetBtn.hidden = false);
      }
    } catch (_) {}
  }

  function savePat(pat) {
    try {
      if (pat) {
        localStorage.setItem(PAT_KEY, pat);
        forgetBtn && (forgetBtn.hidden = false);
      }
    } catch (_) {}
  }

  forgetBtn && forgetBtn.addEventListener('click', function () {
    try { localStorage.removeItem(PAT_KEY); } catch (_) {}
    if (patInput) patInput.value = '';
    forgetBtn.hidden = true;
  });

  // ── Versão semântica ─────────────────────────────────────────────────

  function isNewer(localVer, remoteVer) {
    var local  = localVer.replace(/^v/, '').split('.').map(Number);
    var remote = remoteVer.replace(/^v/, '').split('.').map(Number);
    for (var i = 0; i < 3; i++) {
      var l = local[i] || 0;
      var r = remote[i] || 0;
      if (r > l) return true;
      if (r < l) return false;
    }
    return false;
  }

  async function checkVersion() {
    try {
      var url = 'https://api.github.com/repos/' + owner + '/' + repo + '/contents/public/version.json';
      var res = await fetch(url, { headers: { Accept: 'application/vnd.github.v3+json' } });
      if (!res.ok) { console.warn('[UpdateBanner] GitHub API:', res.status); return; }

      var data      = await res.json();
      var decoded   = atob(data.content.replace(/\n/g, ''));
      var remote    = JSON.parse(decoded);
      var remoteVer = remote.version || '0.0.0';

      if (isNewer(localVer, remoteVer)) {
        var versionsEl = document.getElementById('update-versions');
        if (versionsEl) versionsEl.textContent = 'v' + localVer + ' → v' + remoteVer;
        banner.hidden = false;
        loadPat();
      }
    } catch (err) {
      console.warn('[UpdateBanner] Falha ao verificar versão:', err);
    }
  }

  // ── Disparo do deploy ─────────────────────────────────────────────────

  async function triggerUpdate(pat, bumpType) {
    var statusEl = document.getElementById('update-status');
    var btn      = document.getElementById('update-btn');
    if (!statusEl || !btn) return;

    btn.disabled    = true;
    btn.textContent = 'Enviando…';
    statusEl.hidden = true;

    try {
      var res = await fetch('https://api.github.com/repos/' + owner + '/' + repo + '/dispatches', {
        method: 'POST',
        headers: {
          Authorization:  'token ' + pat,
          Accept:         'application/vnd.github.everest-preview+json',
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          event_type: 'update-template',
          client_payload: {
            triggered_by: 'admin-panel',
            bump_type:    bumpType,
            timestamp:    new Date().toISOString(),
          },
        }),
      });

      if (res.status === 204) {
        savePat(pat);
        statusEl.textContent = '✅ Deploy iniciado! Template atualizado em ~2 min. (bump: ' + bumpType + ')';
        statusEl.className   = 'update-banner__status update-banner__status--success';
        btn.textContent      = 'Deploy em andamento…';
      } else {
        var body = await res.json().catch(() => ({}));
        throw new Error(body.message || 'Status ' + res.status);
      }
    } catch (err) {
      statusEl.textContent = '❌ Erro: ' + (err.message || 'Verifique o PAT e tente novamente.');
      statusEl.className   = 'update-banner__status update-banner__status--error';
      btn.disabled    = false;
      btn.textContent = 'Aplicar Atualização';
    }

    statusEl.hidden = false;
  }

  // ── Listener do botão ────────────────────────────────────────────────

  var btn = document.getElementById('update-btn');
  btn && btn.addEventListener('click', function () {
    var pat      = (patInput ? patInput.value : '').trim();
    var bumpType = 'patch';
    var radios   = document.querySelectorAll('input[name="bump-type"]');
    radios.forEach(function (r) { if (r.checked) bumpType = r.value; });

    if (!pat) {
      var statusEl = document.getElementById('update-status');
      if (statusEl) {
        statusEl.textContent = '⚠️ Informe o GitHub Personal Access Token (PAT) antes de continuar.';
        statusEl.className   = 'update-banner__status update-banner__status--warn';
        statusEl.hidden = false;
      }
      return;
    }

    triggerUpdate(pat, bumpType);
  });

  // ── Init ─────────────────────────────────────────────────────────────
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', checkVersion);
  } else {
    checkVersion();
  }
})();
</script>

<style>
  .update-banner {
    background: linear-gradient(135deg, #1a1a2e 0%, #302b63 100%);
    color: #fff;
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 20px rgba(48, 43, 99, 0.3);
  }

  .update-banner__content {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 1rem;
  }

  .update-banner__icon { font-size: 1.75rem; flex-shrink: 0; }

  .update-banner__text { flex: 1; min-width: 160px; }

  .update-banner__title { display: block; font-size: 1rem; font-weight: 700; }

  .update-banner__subtitle {
    font-size: 0.8rem;
    opacity: 0.75;
    font-family: monospace;
  }

  /* Actions */
  .update-banner__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    width: 100%;
    margin-top: 0.75rem;
  }

  /* PAT row */
  .update-banner__pat-label { font-size: 0.75rem; opacity: 0.8; white-space: nowrap; }

  .update-banner__pat-wrap { display: flex; gap: 0.3rem; align-items: center; }

  .update-banner__pat-input {
    padding: 0.45rem 0.75rem;
    border: 1.5px solid rgba(255, 255, 255, 0.3);
    border-radius: 6px;
    font-size: 0.875rem;
    font-family: monospace;
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    width: 200px;
    transition: border-color 0.15s;
  }
  .update-banner__pat-input::placeholder { opacity: 0.5; }
  .update-banner__pat-input:focus { outline: none; border-color: rgba(255,255,255,0.7); }

  /* Bump selector */
  .update-banner__bump-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    margin-left: auto;
  }

  .update-banner__bump-label { opacity: 0.7; white-space: nowrap; }

  .update-banner__bump-opt {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    cursor: pointer;
    user-select: none;
  }

  /* Buttons */
  .update-banner__btn {
    padding: 0.5rem 1.25rem;
    border: none;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: opacity 0.15s ease, transform 0.1s ease;
    white-space: nowrap;
  }

  .update-banner__btn--primary { background: #fff; color: #302b63; }
  .update-banner__btn--primary:hover:not(:disabled) { opacity: 0.9; transform: translateY(-1px); }

  .update-banner__btn--ghost {
    background: transparent;
    color: rgba(255,255,255,0.6);
    padding: 0.45rem 0.55rem;
    border: 1px solid rgba(255,255,255,0.2);
    font-size: 0.9rem;
  }
  .update-banner__btn--ghost:hover { color: #fff; border-color: rgba(255,255,255,0.5); }

  .update-banner__btn:disabled { opacity: 0.5; cursor: not-allowed; }

  /* Status */
  .update-banner__status {
    margin-top: 0.75rem;
    padding: 0.6rem 1rem;
    border-radius: 6px;
    font-size: 0.875rem;
  }

  .update-banner__status--success { background: rgba(209,250,229,0.15); color: #a7f3d0; }
  .update-banner__status--error   { background: rgba(254,226,226,0.15); color: #fca5a5; }
  .update-banner__status--warn    { background: rgba(254,243,199,0.15); color: #fde68a; }
</style>
