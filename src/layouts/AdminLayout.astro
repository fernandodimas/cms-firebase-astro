---
/**
 * AdminLayout.astro
 *
 * Layout autônomo para o painel administrativo.
 * NÃO depende do Firestore (CMSDocument) — é estático puro.
 */

interface Props {
  title?: string;
  description?: string;
}

const {
  title       = 'Painel Admin — CMS',
  description = 'Painel administrativo do CMS Firebase + Astro.',
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Noindex: painel não deve ser indexado por motores de busca -->
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:inline>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-family: system-ui, -apple-system, sans-serif; }
      body { background: #0f0f14; color: #e2e8f0; line-height: 1.6; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
