---
/**
 * /admin — Painel Administrativo do CMS
 *
 * Página ESTÁTICA (Astro SSG) que injeta a versão atual estaticamente
 * no build e inclui o UpdateBanner para verificação e atualização
 * de templates via GitHub Actions.
 *
 * ACESSO: esta URL (ex: seusite.com/admin) deve ser protegida por senha
 * ou acesso restrito no Firebase Hosting.
 *
 * REGRA DA SKILL: zero bibliotecas externas, sem SSR.
 */

import AdminLayout from '../layouts/AdminLayout.astro';
import UpdateBanner from '../components/UpdateBanner.astro';

// Lê o version.json gerado estaticamente durante o build
// O arquivo está em public/ e será copiado para dist/
import pkg from '../../public/version.json';
const { version: currentVersion } = pkg;

// Configuração do repositório GitHub (substitua pelos seus dados reais)
const REPO_OWNER = 'fernandodimas';
const REPO_NAME  = 'cms-firebase-astro';
---

<AdminLayout
  title="Painel Admin — CMS"
  description="Painel administrativo do CMS Firebase + Astro."
>
  <main class="admin-layout">
    <!-- Cabeçalho do painel -->
    <header class="admin-header">
      <div class="admin-header__brand">
        <span class="admin-header__logo" aria-hidden="true">⚙️</span>
        <div>
          <h1 class="admin-header__title">Painel CMS</h1>
          <p class="admin-header__version">
            Template <code>v{currentVersion}</code>
          </p>
        </div>
      </div>
    </header>

    <div class="admin-body">
      <!--
        UpdateBanner — exibido apenas se houver nova versão disponível.
        A verificação acontece no cliente via GitHub API (sem CORS).
      -->
      <UpdateBanner
        currentVersion={currentVersion}
        repoOwner={REPO_OWNER}
        repoName={REPO_NAME}
      />

      <!-- Seções do painel (expandir conforme necessário) -->
      <section class="admin-card">
        <h2 class="admin-card__title">📄 Conteúdo do Site</h2>
        <p class="admin-card__description">
          Edite o documento no Firestore para atualizar o conteúdo do site.
          Após salvar, clique em "Publicar" para disparar um novo build.
        </p>
        <div class="admin-card__actions">
          <a
            href="https://console.firebase.google.com"
            target="_blank"
            rel="noopener noreferrer"
            class="admin-btn admin-btn--secondary"
          >
            Abrir Firestore Console →
          </a>
        </div>
      </section>

      <section class="admin-card">
        <h2 class="admin-card__title">📊 Status do Deploy</h2>
        <p class="admin-card__description">
          Monitore os deploys em andamento no repositório GitHub.
        </p>
        <div class="admin-card__actions">
          <a
            href={`https://github.com/${REPO_OWNER}/${REPO_NAME}/actions`}
            target="_blank"
            rel="noopener noreferrer"
            class="admin-btn admin-btn--secondary"
          >
            Ver GitHub Actions →
          </a>
        </div>
      </section>
    </div>
  </main>
</AdminLayout>

<style>
  .admin-layout {
    min-height: 100vh;
    background: #0f0f14;
    color: #e2e8f0;
    font-family: system-ui, sans-serif;
  }

  /* ── Header ─────────────────────────────────────── */
  .admin-header {
    background: #1a1a2e;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1.25rem 2rem;
  }

  .admin-header__brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .admin-header__logo { font-size: 1.75rem; }

  .admin-header__title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
    line-height: 1;
  }

  .admin-header__version {
    font-size: 0.75rem;
    opacity: 0.5;
    margin: 0.2rem 0 0;
  }

  .admin-header__version code {
    font-family: monospace;
    background: rgba(255,255,255,0.06);
    padding: 0.1em 0.4em;
    border-radius: 4px;
  }

  /* ── Body ────────────────────────────────────────── */
  .admin-body {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ── Cards ───────────────────────────────────────── */
  .admin-card {
    background: #1a1a2e;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .admin-card__title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  .admin-card__description {
    font-size: 0.875rem;
    opacity: 0.65;
    margin: 0 0 1.25rem;
    line-height: 1.55;
  }

  .admin-card__actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  /* ── Botões ─────────────────────────────────────── */
  .admin-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    font-family: inherit;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: opacity 0.15s ease;
  }

  .admin-btn--secondary {
    background: rgba(255, 255, 255, 0.08);
    color: #e2e8f0;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .admin-btn--secondary:hover { opacity: 0.75; }
</style>
