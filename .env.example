# Variáveis de ambiente para desenvolvimento local
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o arquivo .env!

# Caminho do documento no Firestore (ex: "sites/meu-site")
# Deixe vazio em desenvolvimento para usar sampleData local.
FIRESTORE_DOCUMENT_PATH=

# JSON completo da Service Account do Firebase (para produção/CI).
# Em desenvolvimento, deixe vazio (usa sampleData automaticamente).
FIREBASE_SERVICE_ACCOUNT_JSON=
